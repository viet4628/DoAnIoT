# ── PostgreSQL ──
POSTGRES_DB=doaniotdb
POSTGRES_USER=doaniotuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST_PORT=5434

# ── Spring Boot Backend ──
BACKEND_HOST_PORT=8093
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# ── EMQX MQTT Broker ──
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083
EMQX_COOKIE=CHANGE_ME

# ── MQTTX Web ──
MQTTX_WEB_PORT=8080
